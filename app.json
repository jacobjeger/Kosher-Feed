{
  "expo": {
    "name": "ShiurPod",
    "slug": "shiurpod",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shiurpod",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shiurpod.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.shiurpod.app",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://kosher-feed-production.up.railway.app/"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "backgroundAudio": true
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#0a0f1a"
          }
        }
      ],
      "expo-web-browser",
      "expo-background-task",
      "expo-task-manager",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a73e8",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "./plugins/withAndroidAuto.js"
    ],
    "updates": {
      "url": "https://u.expo.dev/3318cca6-05bb-4658-a9c5-6dccc573953c",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": "1.0.0",
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://kosher-feed-production.up.railway.app/"
      },
      "eas": {
        "projectId": "3318cca6-05bb-4658-a9c5-6dccc573953c"
      }
    }
  }
}
