# Firebase JS SDK 11.x declares peer dependency
# `@react-native-async-storage/async-storage: ^1.18.1`. Expo SDK 54 ships
# 2.2.0 — runtime-compatible with firebase's auth persistence but npm's
# strict-peer-deps mode (npm 7+ default) refuses to install. Railway's
# `npm ci` was failing with:
#
#   Missing: @react-native-async-storage/async-storage@1.24.0 from lock file
#
# legacy-peer-deps=true reverts to npm 6's permissive resolution, which
# is the de-facto standard for Expo projects with RN-flavored peer-dep
# hell. Local installs and Railway builds use the same flag.
legacy-peer-deps=true
